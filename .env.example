# ============================================
# CodeChef Contest MCP Server — Configuration
# ============================================

# CodeChef Authentication
# To get these values:
# 1. Log in to https://www.codechef.com in your browser
# 2. Open DevTools (F12) → Application → Cookies → codechef.com
# 3. Copy the session cookie value
CODECHEF_USERNAME=your_codechef_username
CODECHEF_PASSWORD=your_codechef_password

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Sandbox Configuration
SANDBOX_MEMORY_LIMIT=256m
SANDBOX_CPU_LIMIT=1
SANDBOX_PID_LIMIT=64
COMPILE_TIMEOUT=10
EXECUTION_TIMEOUT=5
STRESS_TEST_TIMEOUT=15

# Solver Configuration
MAX_RETRIES=3
CONFIDENCE_THRESHOLD=75

# Redis (optional — falls back to in-memory cache)
REDIS_URL=redis://localhost:6379

# Database
DATABASE_URL=sqlite+aiosqlite:///./codechef_mcp.db
